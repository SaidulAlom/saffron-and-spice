# ============================================================
# Saffron & Spice - Environment Variables Reference
# Copy this file to .env.local and fill in real values.
# NEVER commit .env.local to source control.
# ============================================================

# Frontend (Vite) - bundled into the browser bundle
# VITE_ prefix makes these accessible in React via import.meta.env
VITE_SUPABASE_URL="https://your-project-ref.supabase.co"
VITE_SUPABASE_ANON_KEY="sb_publishable_xxxxxxxxxxxxxxxxxxxx"
VITE_SITE_URL="http://localhost:3000"
VITE_GA_ID="G-XXXXXXXXXX"

# Server-side (Express server/index.ts) - NEVER expose to the browser

# Same Supabase project URL (no VITE_ prefix - stays on the server)
SUPABASE_URL="https://your-project-ref.supabase.co"

# Option A: Use anon/publishable key (requires anon INSERT RLS policies in SQL)
SUPABASE_ANON_KEY="sb_publishable_xxxxxxxxxxxxxxxxxxxx"

# Option B (recommended): Use the service-role key - bypasses RLS entirely.
# Get it from: Supabase Dashboard -> Project Settings -> API -> service_role
# When set, the anon INSERT RLS policies are no longer needed.
# SUPABASE_SERVICE_ROLE_KEY="your-service-role-secret-key"

# CSRF protection secret - use a long random string (32+ chars)
CSRF_SECRET="replace-with-a-long-random-secret-at-least-32-chars"

# Gemini AI API key (only needed for the AI chat feature)
# GEMINI_API_KEY="your-gemini-api-key"

# URL of your deployed frontend (used for CORS allow-list in production)
APP_URL="http://localhost:3000"

# Optional local SQLite path for the fallback/local DB helper
# The active write routes currently use Supabase, but this keeps the local DB helper valid.
DB_PATH="./data/saffron-and-spice.db"
